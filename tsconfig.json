{
	"compilerOptions": {
		"outDir": "./dist/",
		"module": "commonjs",
		"target": "es2017",
		"jsx": "react",
		"allowJs": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"skipLibCheck": true,
		"baseUrl": "."
	},
	"include": ["src/**/*", "api/**/*"],
	"exclude": ["node_modules", "dist", "publish"]
}
