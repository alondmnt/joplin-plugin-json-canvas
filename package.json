{
	"name": "joplin-plugin-jsoncanvas",
	"version": "0.0.1",
	"private": true,
	"description": "Interactive JSON Canvas editor for Joplin notes.",
	"author": "alondmnt",
	"homepage": "https://github.com/alondmnt/joplin-plugin-jsoncanvas",
	"repository": {
		"type": "git",
		"url": "https://github.com/alondmnt/joplin-plugin-jsoncanvas.git"
	},
	"bugs": {
		"url": "https://github.com/alondmnt/joplin-plugin-jsoncanvas/issues"
	},
	"scripts": {
		"dist": "webpack --env joplin-plugin-config=buildMain && webpack --env joplin-plugin-config=buildExtraScripts && webpack --env joplin-plugin-config=createArchive",
		"dev": "concurrently \"webpack --watch --env joplin-plugin-config=buildMain\" \"webpack --watch --env joplin-plugin-config=buildExtraScripts\"",
		"lint": "eslint . --ext .ts && prettier --check . && tsc --noEmit",
		"lint:fix": "eslint . --ext .ts --fix && prettier --write .",
		"prepare": "npm run dist",
		"updateVersion": "webpack --env joplin-plugin-config=updateVersion"
	},
	"license": "MIT",
	"keywords": [
		"joplin-plugin"
	],
	"files": [
		"publish"
	],
	"devDependencies": {
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^18.19.0",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"chalk": "^4.1.0",
		"concurrently": "^8.2.0",
		"copy-webpack-plugin": "^11.0.0",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-boundaries": "^4.2.0",
		"fs-extra": "^10.1.0",
		"glob": "^8.0.3",
		"prettier": "^3.3.0",
		"tar": "^6.1.11",
		"ts-loader": "^9.5.0",
		"typescript": "^5.5.0",
		"webpack": "^5.94.0",
		"webpack-cli": "^5.1.4"
	},
	"dependencies": {
		"json-canvas-viewer": "4.2.1",
		"markdown-it": "^14.1.1"
	}
}
