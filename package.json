{
  "name": "js-canvas-spike",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "measure": "vite build && du -k dist/assets/*.js | sort -n && echo '--- gzipped ---' && for f in dist/assets/*.js; do printf '%s\\t' \"$(gzip -c \"$f\" | wc -c)\"; echo \"$f\"; done | sort -n"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "@inditextech/weave-renderer-konva-base": "^3.8.0",
    "@inditextech/weave-sdk": "^3.8.0",
    "@inditextech/weave-store-standalone": "^3.8.0",
    "@inditextech/weave-types": "^3.8.0",
    "json-canvas-viewer": "^4.2.1",
    "konva": "^10.0.2",
    "markdown-it": "^14.1.1",
    "yjs": "^13.6.27"
  }
}
